# Generated data and model artifacts — not tracked in version control.
# To reproduce: see README.md "Reproducing from scratch" section.

# ── large binary datasets ─────────────────────────────────────────────────────
data/mixed_distribution_v2/
data/identifiable_uniform_v1/
data/temporal_v1/
data/temporal_test/
data/process_noise.npz
# keep .gitkeep so the empty data/ dir is tracked
!data/.gitkeep

# ── trained model weights ─────────────────────────────────────────────────────
models/
!models/.gitkeep

# ── evaluation results (generated by eval/run_all.py) ────────────────────────
results/
!results/.gitkeep

# ── generated figures ─────────────────────────────────────────────────────────
/figures/
!figures/.gitkeep

# ── runtime logs ─────────────────────────────────────────────────────────────
logs/
*.log
session_export.txt

# ── Python cache ─────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ── OS and editor artifacts ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── local Claude Code settings ───────────────────────────────────────────────
.claude/
src/.claude/
